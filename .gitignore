# --- R session artifacts ---
.Rproj.user/
.Rhistory
.RData
.Ruserdata
.Renviron
*.Rcheck/

# --- renv: track the lockfile + activate.R + settings.json, ignore the library ---
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/

# --- regenerable pipeline outputs (recreated by running the pipeline) ---
_targets/
outputs/models/
outputs/figures/working/
outputs/figures/diagnostic/
outputs/_experiments/
logs/

# --- LaTeX build artifacts (from building the DAG .tex figures) ---
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
dags/*.pdf

# --- macOS ---
.DS_Store

# --- agent / IDE session state (must never enter the deposit) ---
.claude/
.vscode/
.idea/
